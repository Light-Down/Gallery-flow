generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photographer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logoUrl      String?
  accentColor  String  @default("#1a1a1a")
  footerText   String?

  googleReviewUrl   String?
  secondReviewUrl   String?
  secondReviewLabel String?

  clients   Client[]
  galleries Gallery[]
}

model Client {
  id           String   @id @default(cuid())
  email        String
  name         String
  password     String
  createdAt    DateTime @default(now())

  photographerId String
  photographer   Photographer @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  galleries  Gallery[]
  favorites  Favorite[]

  @@unique([email, photographerId])
}

model Gallery {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String?
  design       GalleryDesign @default(GRID)
  status       GalleryStatus @default(DRAFT)
  greetingText String?
  expiresAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  photographerId String
  photographer   Photographer @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  photos Photo[]
}

model Photo {
  id          String   @id @default(cuid())
  filename    String
  previewUrl  String
  driveLink   String?
  isSneakPeak Boolean  @default(false)
  sortOrder   Int      @default(0)
  width       Int?
  height      Int?
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  favorites Favorite[]
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  photoId String
  photo   Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([clientId, photoId])
}

enum GalleryDesign {
  MASONRY
  GRID
  HORIZONTAL
  SLIDESHOW
  MAGAZINE
  POLAROID
}

enum GalleryStatus {
  DRAFT
  SNEAK_PEAK
  PUBLISHED
  EXPIRED
}
